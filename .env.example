# AWS
AWS_REGION=us-east-1

# DynamoDB
JOBS_TABLE_NAME=compliance-jobs
API_KEYS_TABLE_NAME=compliance-api-keys

# SQS
AUDIT_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/996561439262/compliance-audit-jobs.fifo

# S3
INDEXES_BUCKET=compliance-indexes-prod
REPORTS_BUCKET=compliance-reports-prod
PDFS_BUCKET=compliance-pdfs-prod

# Auth
DEV_API_KEY=dev-key-001
ADMIN_API_KEY=change-me-in-production

# PDF Generator
FRONTEND_BASE_URL=https://app.yourdomain.com

# Environment (development | production)
ENVIRONMENT=development

# Email (SES)
FROM_EMAIL=noreply@yourdomain.com

# Optional: override Nova model
NOVA_REPORT_MODEL=amazon.nova-pro-v1:0
NOVA_LITE_MODEL=amazon.nova-lite-v1:0

# Optional: SAM.gov API key (step 1 — federal debarment)
SAM_GOV_API_KEY=
